{
  "name": "maestro-chat",
  "displayName": "Maestro Chat",
  "description": "ChatParticipant @maestro — 강제 배지 출력 + Maestro 파이프라인 오케스트레이션",
  "version": "0.0.1",
  "publisher": "local",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onChatParticipant:maestro",
    "onView:maestroChat.sidebar",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "maestro",
        "name": "maestro",
        "fullName": "Maestro",
        "description": "강제 배지 + 멀티 에이전트 오케스트레이션",
        "isSticky": true
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "maestroChat",
          "title": "Maestro",
          "icon": "$(symbol-event)"
        }
      ]
    },
    "views": {
      "maestroChat": [
        {
          "id": "maestroChat.sidebar",
          "name": "Maestro 상태",
          "icon": "$(symbol-event)"
        },
        {
          "id": "maestroChat.mcp",
          "name": "MCP 상태",
          "icon": "$(plug)"
        }
      ]
    },
    "commands": [
      {
        "command": "maestroChat.setGithubPat",
        "title": "Maestro: Set GITHUB_PAT",
        "icon": "$(key)"
      },
      {
        "command": "maestroChat.clearGithubPat",
        "title": "Maestro: Clear GITHUB_PAT",
        "icon": "$(clear-all)"
      },
      {
        "command": "maestroChat.openEnvFile",
        "title": "Maestro: Open .env File"
      },
      {
        "command": "maestroChat.openHarness",
        "title": "Maestro: Open Harness Folder"
      },
      {
        "command": "maestroChat.openLogs",
        "title": "Maestro: Open Logs Folder"
      },
      {
        "command": "maestroChat.refresh",
        "title": "Maestro: Refresh Sidebar",
        "icon": "$(refresh)"
      },
      {
        "command": "maestroChat.showOutput",
        "title": "Maestro: Show Output Log",
        "icon": "$(output)"
      },
      {
        "command": "maestroChat.openMcpConfig",
        "title": "Maestro: Open MCP Config",
        "icon": "$(json)"
      },
      {
        "command": "maestroChat.runExtensionTests",
        "title": "Maestro: Run Extension Tests",
        "icon": "$(beaker)"
      },
      {
        "command": "maestroChat.clearActionItems",
        "title": "Maestro: Clear Action Items",
        "icon": "$(check-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "maestroChat.refresh",
          "when": "view == maestroChat.sidebar",
          "group": "navigation"
        },
        {
          "command": "maestroChat.setGithubPat",
          "when": "view == maestroChat.sidebar",
          "group": "navigation"
        },
        {
          "command": "maestroChat.showOutput",
          "when": "view == maestroChat.sidebar",
          "group": "navigation"
        },
        {
          "command": "maestroChat.runExtensionTests",
          "when": "view == maestroChat.sidebar",
          "group": "navigation"
        },
        {
          "command": "maestroChat.openMcpConfig",
          "when": "view == maestroChat.mcp",
          "group": "navigation"
        },
        {
          "command": "maestroChat.refresh",
          "when": "view == maestroChat.mcp",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "maestroChat.setGithubPat",
          "when": "view == maestroChat.sidebar && viewItem == pat-unset",
          "group": "inline"
        },
        {
          "command": "maestroChat.setGithubPat",
          "when": "view == maestroChat.sidebar && viewItem == pat-set",
          "group": "inline"
        },
        {
          "command": "maestroChat.clearGithubPat",
          "when": "view == maestroChat.sidebar && viewItem == pat-set"
        },
        {
          "command": "maestroChat.clearActionItems",
          "when": "view == maestroChat.sidebar && viewItem == action-item"
        }
      ]
    },
    "languageModelTools": [
      {
        "name": "maestro_read_file",
        "displayName": "Maestro: Read File",
        "modelDescription": "harness 워크스페이스 내의 파일을 읽습니다 (최대 100KB, 기본). path는 harness 부모 기준 상대경로 또는 절대경로.",
        "userDescription": "harness 워크스페이스 안의 파일 내용을 읽습니다.",
        "canBeReferencedInPrompt": false,
        "tags": [
          "maestro"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "파일 경로 (harness 부모 기준 상대 또는 절대)"
            },
            "maxBytes": {
              "type": "number",
              "description": "최대 읽기 바이트 (기본 100000, 상한 1000000)"
            }
          },
          "required": [
            "path"
          ]
        }
      },
      {
        "name": "maestro_list_files",
        "displayName": "Maestro: List Files",
        "modelDescription": "harness 워크스페이스 안의 파일 목록을 읽기 전용으로 나열합니다. node_modules, .git, out, dist는 기본 제외합니다.",
        "userDescription": "파일 목록을 읽기 전용으로 나열합니다.",
        "canBeReferencedInPrompt": false,
        "tags": [
          "maestro"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "root": {
              "type": "string",
              "description": "검색 루트 (harness 부모 기준 상대 또는 절대, 기본 .)"
            },
            "maxFiles": {
              "type": "number",
              "description": "최대 파일 수 (기본 200, 상한 1000)"
            }
          }
        }
      },
      {
        "name": "maestro_search_files",
        "displayName": "Maestro: Search Files",
        "modelDescription": "harness 워크스페이스 안에서 정규식 패턴을 읽기 전용으로 검색합니다.",
        "userDescription": "파일 내용을 읽기 전용으로 검색합니다.",
        "canBeReferencedInPrompt": false,
        "tags": [
          "maestro"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "pattern": {
              "type": "string",
              "description": "검색할 JavaScript 정규식 패턴"
            },
            "root": {
              "type": "string",
              "description": "검색 루트 (harness 부모 기준 상대 또는 절대, 기본 .)"
            },
            "include": {
              "type": "string",
              "description": "파일명 와일드카드 필터 예: *.ts"
            },
            "regex": {
              "type": "boolean",
              "description": "true면 pattern을 정규식으로 해석합니다. 기본 false는 literal 검색입니다."
            },
            "maxMatches": {
              "type": "number",
              "description": "최대 매치 수 (기본 100, 상한 500)"
            }
          },
          "required": [
            "pattern"
          ]
        }
      },
      {
        "name": "maestro_write_file",
        "displayName": "Maestro: Write File",
        "modelDescription": "harness 워크스페이스에 파일을 씁니다. .env, 키 파일, 보호 디렉토리(.github/hooks 등)는 file-guard 정책으로 차단되거나 사용자 확인을 요구합니다.",
        "userDescription": "파일을 생성/덮어쓰기 — 가드 정책을 적용합니다.",
        "canBeReferencedInPrompt": false,
        "tags": [
          "maestro"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            },
            "content": {
              "type": "string"
            }
          },
          "required": [
            "path",
            "content"
          ]
        }
      },
      {
        "name": "maestro_run_terminal",
        "displayName": "Maestro: Run Terminal",
        "modelDescription": "터미널 명령을 사용자 확인 후 실행합니다. rm -rf, git push --force 등 파괴 패턴은 safety-guard로 차단/경고합니다.",
        "userDescription": "터미널 명령 실행 (가드 적용).",
        "canBeReferencedInPrompt": false,
        "tags": [
          "maestro"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "command": {
              "type": "string",
              "description": "실행할 명령"
            },
            "cwd": {
              "type": "string",
              "description": "작업 디렉토리 (선택)"
            }
          },
          "required": [
            "command"
          ]
        }
      },
      {
        "name": "maestro_invoke_agent",
        "displayName": "Maestro: Invoke Agent",
        "modelDescription": "single-session 모드에서 Maestro 하위 에이전트를 현재 요청 컨텍스트 안에서 호출합니다. extension이 제공한 context_id를 반드시 그대로 전달해야 합니다.",
        "userDescription": "Maestro 하위 에이전트를 호출합니다.",
        "canBeReferencedInPrompt": false,
        "tags": [
          "maestro"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "context_id": {
              "type": "string",
              "description": "extension이 이번 요청에 발급한 컨텍스트 ID"
            },
            "agent_name": {
              "type": "string",
              "description": "호출할 Maestro 에이전트 이름"
            },
            "task": {
              "type": "string",
              "description": "해당 에이전트에게 맡길 구체적인 작업"
            },
            "prior_context": {
              "type": "string",
              "description": "이전 단계 출력 또는 추가 컨텍스트"
            }
          },
          "required": [
            "context_id",
            "agent_name",
            "task"
          ]
        }
      }
    ],
    "configuration": {
      "title": "Maestro Chat",
      "properties": {
        "maestroChat.harnessPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the cloned `.github` harness directory (the folder that contains `hooks/scripts/maestro-router.js`).\n\n비워두면 자동 발견을 시도한다:\n1. 워크스페이스에 `.github/` 하위 폴더가 있으면 그것을 사용\n2. 워크스페이스 폴더 자체가 `.github` 레이아웃이면 그것을 사용 (clone standalone)\n3. 둘 다 실패하면 에러"
        },
        "maestroChat.routerTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "maximum": 60000,
          "description": "legacy maestro-router.js child_process 타임아웃 (ms)"
        },
        "maestroChat.useLegacyRouter": {
          "type": "boolean",
          "default": false,
          "description": "true면 extension 내부 TS router 대신 기존 hooks/scripts/maestro-router.js를 child_process로 호출합니다. 마이그레이션 검증용 legacy fallback."
        },
        "maestroChat.debug": {
          "type": "boolean",
          "default": false,
          "description": "true로 두면 router stdout/stderr와 발견된 harness path를 응답에 표시 (디버깅용)"
        },
        "maestroChat.executorMode": {
          "type": "string",
          "default": "single-session",
          "enum": [
            "passthrough",
            "single-session",
            "multi-agent"
          ],
          "enumDescriptions": [
            "Phase 1 동작: 분류 → 배지 출력 → Maestro userMessage 전체를 단일 LLM 호출. 빠르지만 LLM이 멀티 에이전트 흐름을 스스로 모방해야 함.",
            "단일 LLM 세션에서 읽기 전용 Maestro 도구 결과를 messages 배열에 누적하며 답변. 질문/조사에 빠르고 안전한 모드.",
            "Phase 2 동작: 파이프라인의 각 step마다 별개 vscode.lm 호출 (시스템=해당 agent의 .agent.md 본문). 진짜 멀티 에이전트 실행. 토큰 더 소비, 시간 더 걸림."
          ],
          "description": "응답 생성 방식: passthrough(단일 호출), single-session(읽기 도구 포함 단일 세션), multi-agent(파이프라인 step별 호출)"
        },
        "maestroChat.modelFamily": {
          "type": "string",
          "default": "",
          "markdownDescription": "Preferred Copilot language model family for `vscode.lm.selectChatModels`. Empty means the first available Copilot model. Examples depend on installed Copilot support and may include `gpt-4o`, `gpt-4.1`, `claude-sonnet`."
        },
        "maestroChat.streamAgentOutputs": {
          "type": "boolean",
          "default": true,
          "description": "multi-agent 모드에서 각 에이전트 출력을 채팅에 실시간 표시할지 여부. false면 요약만 표시하고 logs/pipeline.jsonl에는 기록."
        },
        "maestroChat.maxPriorStepChars": {
          "type": "number",
          "default": 4000,
          "minimum": 500,
          "maximum": 20000,
          "description": "multi-agent 모드에서 다음 에이전트에게 전달할 이전 step 출력 최대 문자 수."
        },
        "maestroChat.maxLoggedStepChars": {
          "type": "number",
          "default": 4000,
          "minimum": 500,
          "maximum": 20000,
          "description": "logs/pipeline.jsonl에 저장할 각 에이전트 출력 최대 문자 수."
        },
        "maestroChat.legacyMcpEnabled": {
          "type": "boolean",
          "default": false,
          "description": "true면 기존 github-state MCP를 병행 사용 중임을 사이드바에 표시합니다. Extension은 이 설정 없이도 독립 동작합니다."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && node tests/run-tests.cjs",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.7.0"
  }
}
